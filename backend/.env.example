# ============================
# Aplicação
# ============================
APP_NAME=Clinic Management API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ============================
# Segurança / JWT
# ============================
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-use-a-strong-random-secret-with-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# Algoritmo de hash de senha: argon2 recomendado. bcrypt fica para hashes legados.
PASSWORD_HASH_SCHEME=argon2

# ============================
# Banco de dados (MySQL)
# ============================
# Drivers suportados: mysql, postgresql
DB_DRIVER=mysql
DB_HOST=db
DB_PORT=3306
DB_USER=clinic
DB_PASSWORD=clinic_password
DB_NAME=clinic_db
DB_ROOT_PASSWORD=root_password

# String completa (sobrescreve as variáveis acima se preenchida)
# Ex MySQL:    mysql+pymysql://clinic:clinic_password@db:3306/clinic_db
# Ex Postgres: postgresql+psycopg2://clinic:clinic_password@db:5432/clinic_db
DATABASE_URL=

# ============================
# CORS
# ============================
# Lista JSON de origens permitidas
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ============================
# Bootstrap inicial (primeiro admin)
# ============================
# Usados pelo comando: python -m app.cli.create_admin
INITIAL_ADMIN_NAME=Administrador
INITIAL_ADMIN_EMAIL=admin@clinic.local
INITIAL_ADMIN_PASSWORD=change-me-strong-password
